# Build trees
/build/
/out/
**/build/
cmake-build-*/

# CUTLASS and other fetched content
_deps/
/third_party/

# Experiment outputs. Generated benchmark rows are not committed, but the ncu
# diagnostic text pages and round metadata are: the diagnostic log points at
# them as evidence. The large binary ncu and nsys reports stay out (regenerable).
experiments/results/**/*.jsonl
experiments/results/summary_*.csv

# Nsight artifacts
*.ncu-rep
*.nsys-rep
*.sqlite

